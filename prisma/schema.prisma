generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Diagram {
  id        String   @id @default(cuid())
  name      String
  content   String
  viewMode  String   @default("system-architecture")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
